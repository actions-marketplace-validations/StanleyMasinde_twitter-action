{
  "name": "twitter-action",
  "version": "1.0.0",
  "description": "GitHub Action that installs the Twitter CLI and publishes a tweet.",
  "keywords": [
    "CI",
    "Twitter",
    "CLI",
    "Releases",
    "Actions"
  ],
  "license": "MIT",
  "author": "Stanley Masinde",
  "type": "module",
  "main": "dist/index.js",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json && rollup --config rollup.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.0.0",
    "rollup": "^4.59.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0"
  }
}
